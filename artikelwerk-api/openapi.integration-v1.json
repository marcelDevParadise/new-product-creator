      "FeatureFlags": { "type": "object", "additionalProperties": { "type": "boolean" }, "required": ["articleSearch", "articleRead", "articleWrite", "inventoryWrite", "bulkArticleUpdate", "changeFeed"], "properties": { "articleSearch": { "type": "boolean" }, "articleRead": { "type": "boolean" }, "articleWrite": { "type": "boolean" }, "attributeRead": { "type": "boolean" }, "attributeWrite": { "type": "boolean" }, "descriptionRead": { "type": "boolean" }, "descriptionWrite": { "type": "boolean" }, "imageRead": { "type": "boolean" }, "imageWrite": { "type": "boolean" }, "variationWrite": { "type": "boolean" }, "childArticleWrite": { "type": "boolean" }, "basePriceWrite": { "type": "boolean" }, "shopRead": { "type": "boolean" }, "tenantWrite": { "type": "boolean" }, "priceRead": { "type": "boolean" }, "priceWrite": { "type": "boolean" }, "inventoryRead": { "type": "boolean" }, "inventoryWrite": { "type": "boolean" }, "categoryRead": { "type": "boolean" }, "categoryWrite": { "type": "boolean" }, "lifecycleWrite": { "type": "boolean" }, "supplierRead": { "type": "boolean" }, "supplierWrite": { "type": "boolean" }, "imageUpdate": { "type": "boolean" }, "variationUpdate": { "type": "boolean" }, "bulkArticleUpdate": { "type": "boolean" }, "changeFeed": { "type": "boolean" } } },
      "IntegrationContext": { "type": "object", "required": ["tenants", "units", "attributes"], "properties": { "tenants": { "type": "array", "items": { "$ref": "#/components/schemas/Tenant" } }, "units": { "type": "array", "items": { "$ref": "#/components/schemas/Unit" } }, "attributes": { "type": "array", "items": { "$ref": "#/components/schemas/Attribute" } } }, "example": { "tenants": [{ "id": 4, "name": "CleanYourLeather", "articleCount": 1520, "isDefault": true }], "units": [{ "id": 1, "name": "Milliliter", "code": "ml" }], "attributes": [{ "id": "material", "name": "Material", "dataType": "text", "allowsCustomValue": true }] } },
      "Tenant": { "type": "object", "required": ["id", "name", "articleCount", "isDefault"], "properties": { "id": { "type": "integer", "minimum": 1 }, "name": { "type": "string" }, "articleCount": { "type": "integer", "minimum": 0 }, "isDefault": { "type": "boolean" } } },
      "NextArticleNumber": { "type": "object", "required": ["tenantId", "tenantName", "prefix", "number", "sequence"], "properties": { "tenantId": { "type": "integer", "minimum": 1 }, "tenantName": { "type": "string", "const": "CleanYourLeather" }, "prefix": { "type": "string", "const": "CYL-" }, "number": { "type": "string", "pattern": "^CYL-[0-9]{5}$" }, "sequence": { "type": "integer", "minimum": 1, "maximum": 99999 } }, "example": { "tenantId": 4, "tenantName": "CleanYourLeather", "prefix": "CYL-", "number": "CYL-00999", "sequence": 999 } },
      "Unit": { "type": "object", "required": ["id", "name", "code"], "description": "JTL-Maßeinheit. IDs sind installationsabhängig und ausschließlich aus /context zu übernehmen. Artikelwerk führt keine automatische Umrechnung durch.", "properties": { "id": { "type": "integer", "minimum": 0 }, "name": { "type": "string" }, "code": { "type": ["string", "null"] } } },
      "Attribute": { "type": "object", "required": ["id", "name"], "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "dataType": { "type": "string", "enum": ["integer", "decimal", "text", "date"] }, "allowsCustomValue": { "type": "boolean" } } },
      "AttributeValue": { "type": "object", "required": ["id", "attributeId", "label"], "properties": { "id": { "type": "string" }, "attributeId": { "type": "string" }, "label": { "type": "string" } } },
      "Dimensions": { "type": "object", "additionalProperties": false, "properties": { "length": { "type": "number", "minimum": 0, "default": 0 }, "width": { "type": "number", "minimum": 0, "default": 0 }, "height": { "type": "number", "minimum": 0, "default": 0 } } },
      "CreateArticleInput": { "type": "object", "additionalProperties": false, "required": ["sku", "name", "tenantIds"], "properties": { "sku": { "type": "string", "minLength": 1, "maxLength": 100 }, "name": { "type": "string", "minLength": 1, "maxLength": 255 }, "tenantIds": { "type": "array", "minItems": 1, "maxItems": 20, "items": { "type": "integer", "minimum": 1 } }, "active": { "type": "boolean", "default": true }, "inventoryTracking": { "type": "boolean", "default": true }, "description": { "type": ["string", "null"], "maxLength": 2000000 }, "shortDescription": { "type": ["string", "null"], "maxLength": 2000000 }, "gtin": { "type": ["string", "null"], "maxLength": 255 }, "productGroupId": { "type": "integer", "minimum": 0, "default": 0 }, "manufacturerId": { "type": "integer", "minimum": 0, "default": 0 }, "taxClassId": { "type": "integer", "minimum": 0, "default": 0 }, "dimensions": { "$ref": "#/components/schemas/Dimensions" }, "weight": { "type": "number", "minimum": 0, "default": 0 }, "shippingWeight": { "type": "number", "minimum": 0, "default": 0 } }, "example": { "sku": "CYL-00999", "name": "Beispielartikel", "tenantIds": [4], "active": true, "inventoryTracking": true, "description": "Beschreibung", "shortDescription": "Kurzbeschreibung", "gtin": "4000000000000", "productGroupId": 0, "manufacturerId": 0, "taxClassId": 0, "dimensions": { "length": 0, "width": 0, "height": 0 }, "weight": 0, "shippingWeight": 0 } },
      "CreatedArticle": { "type": "object", "required": ["id", "sku", "name", "tenantIds"], "properties": { "id": { "type": "string" }, "sku": { "type": "string" }, "name": { "type": "string" }, "tenantIds": { "type": "array", "items": { "type": "integer" } } } },
      "CreateArticleResponse": { "type": "object", "required": ["operationId", "article"], "properties": { "operationId": { "type": "string", "format": "uuid" }, "article": { "$ref": "#/components/schemas/CreatedArticle" } }, "example": { "operationId": "f9be70ad-24b9-45b6-9301-32173972f457", "article": { "id": "12345", "sku": "CYL-00999", "name": "Beispielartikel", "tenantIds": [4] } } },
      "SetAttributeInput": { "type": "object", "additionalProperties": false, "required": ["attributeId", "value"], "properties": { "attributeId": { "type": "string", "minLength": 1, "maxLength": 100 }, "value": { "type": "string", "minLength": 1, "maxLength": 4000 } }, "example": { "attributeId": "material", "value": "Leder" } },
      "SetAttributeResponse": { "type": "object", "required": ["operationId", "articleId", "attributeId", "previousValue", "value", "action"], "properties": { "operationId": { "type": "string", "format": "uuid" }, "articleId": { "type": "string" }, "attributeId": { "type": "string" }, "previousValue": { "type": ["string", "null"] }, "value": { "type": "string" }, "action": { "type": "string", "enum": ["insert", "append", "overwrite"] } }, "example": { "operationId": "f9be70ad-24b9-45b6-9301-32173972f457", "articleId": "12345", "attributeId": "material", "previousValue": null, "value": "Leder", "action": "insert" } },
      "CreateImageInput": { "type": "object", "additionalProperties": false, "required": ["filename", "imageBase64", "tenantIds"], "properties": { "filename": { "type": "string", "minLength": 1, "maxLength": 255, "pattern": "\\.(jpe?g|png|webp)$" }, "imageBase64": { "type": "string", "minLength": 16, "maxLength": 14000000, "contentEncoding": "base64" }, "tenantIds": { "type": "array", "minItems": 1, "maxItems": 20, "items": { "type": "integer", "minimum": 1 } }, "order": { "type": "integer", "minimum": 1, "maximum": 1000 } }, "example": { "filename": "CYL-00999-01.jpg", "imageBase64": "<BASE64>", "tenantIds": [4], "order": 1 } },
