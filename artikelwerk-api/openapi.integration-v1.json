      "ImageId": { "name": "imageId", "in": "path", "required": true, "schema": { "type": "string" } },
      "ValueId": { "name": "valueId", "in": "path", "required": true, "schema": { "type": "string" } },
      "JobId": { "name": "jobId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
