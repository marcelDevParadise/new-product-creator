{
  "openapi": "3.1.0",
  "info": {
    "title": "Artikelwerk Integrations-API",
    "version": "1.1.0",
    "description": "Verbindlicher Vertrag der implementierten P0-, P1- und P2-Integrations-API. Verkaufspreise werden netto geführt; Bruttowerte sind abgeleitet."
  },
  "servers": [{ "url": "/api/integrations/v1" }],
  "security": [{ "bearerAuth": [] }],
  "x-artikelwerk-contract": {
    "requestBodyLimitBytes": 15728640,
    "rateLimit": { "requests": 120, "windowSeconds": 60, "key": "authenticated API token", "retryHeader": "Retry-After" },
    "idempotencyKey": { "pattern": "^[A-Za-z0-9_.:-]{8,100}$", "requiredFor": ["createArticle", "uploadArticleImage", "createVariation", "createChildArticle", "adjustInventory", "activateArticle", "deactivateArticle"] },
    "existingSku": "POST /articles returns 409 CONFLICT and never updates an existing article.",
    "contextValues": "Only active, non-excluded tenants are returned. Writes reject tenants that were deleted, disabled or excluded after context retrieval. Missing attribute values are rejected with 400."
  },
  "x-artikelwerk-sql-requirements": { "inventoryAdjustment": "SQL-Mapping commands.inventoryAdjustmentProcedure muss auf eine validierte, transaktionale JTL-Lagerbuchungsprozedur zeigen; andernfalls meldet capabilities.features.inventoryWrite=false." },
  "paths": {
    "/capabilities": {
      "get": {
        "operationId": "getCapabilities",
        "summary": "Aktivierte Integrationsfähigkeiten laden",
        "responses": {
          "200": { "description": "Aktuelle Fähigkeiten", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Capabilities" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }, "429": { "$ref": "#/components/responses/RateLimited" }, "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/context": {
      "get": {
        "operationId": "getContext",
        "summary": "Aktive Mandanten, Maßeinheiten und Attribute laden",
        "responses": {
          "200": { "description": "Schreibkontext", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/IntegrationContext" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }, "429": { "$ref": "#/components/responses/RateLimited" }, "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/context/attributes/{id}/values": {
      "get": {
        "operationId": "getAttributeValues",
        "summary": "Aktuelle Werte eines schreibbaren Attributs laden",
        "parameters": [{ "$ref": "#/components/parameters/AttributeId" }],
        "responses": {
          "200": { "description": "Attributwerte", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/AttributeValue" } }, "example": [{ "id": "17", "attributeId": "material", "label": "Leder" }] } } },
          "400": { "$ref": "#/components/responses/BadRequest" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "429": { "$ref": "#/components/responses/RateLimited" }, "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/tenants/{tenantId}/next-article-number": {
      "get": {
        "operationId": "getNextArticleNumber",
        "summary": "Nächste freie Artikelnummer für CleanYourLeather laden",
        "description": "Berücksichtigt dem angefragten Mandanten direkt zugeordnete Artikel sowie Artikel ohne jegliche Verkaufskanal-Zuordnung, jeweils im exakten Format CYL- plus fünf Ziffern. Artikel mit ausschließlicher Zuordnung zu einem fremden Mandanten bleiben unberücksichtigt. CYL-00001 ist reserviert und wird nie vorgeschlagen. Geliefert wird die kleinste noch unbelegte Sequenz ab CYL-00002; Lücken werden vor höheren Nummern verwendet. Abweichende historische SKUs bleiben unberücksichtigt. Die Nummer ist eine Vorschau; erst POST /articles reserviert sie verbindlich.",
        "parameters": [{ "name": "tenantId", "in": "path", "required": true, "schema": { "type": "integer", "minimum": 1 }, "example": 4 }],
        "responses": {
          "200": { "description": "Nächste freie Artikelnummer", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NextArticleNumber" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "429": { "$ref": "#/components/responses/RateLimited" }, "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/articles": {
      "get": { "operationId": "searchArticles", "summary": "Artikel exakt nach SKU oder weiteren Identifikatoren suchen", "x-required-scope": "articles:read", "parameters": [{ "name": "tenantId", "in": "query", "required": true, "schema": { "type": "integer", "minimum": 1 } }, { "name": "sku", "in": "query", "schema": { "type": "string" } }, { "name": "gtin", "in": "query", "schema": { "type": "string" } }, { "name": "manufacturerNumber", "in": "query", "schema": { "type": "string" } }, { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["active", "inactive"] } }, { "name": "modifiedSince", "in": "query", "schema": { "type": "string", "format": "date-time" } }], "responses": { "200": { "description": "Seitenergebnis mit Revision je Artikel" }, "400": { "$ref": "#/components/responses/BadRequest" }, "403": { "$ref": "#/components/responses/Forbidden" } } },
      "post": {
        "operationId": "createArticle",
        "summary": "Artikel idempotent anlegen",
        "description": "Eine vorhandene SKU wird niemals aktualisiert, sondern mit 409 abgewiesen.",
        "parameters": [{ "$ref": "#/components/parameters/IdempotencyKey" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateArticleInput" } } } },
        "responses": {
          "201": { "description": "Artikel angelegt", "headers": { "X-Idempotent-Replay": { "$ref": "#/components/headers/IdempotentReplay" } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateArticleResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "409": { "$ref": "#/components/responses/Conflict" }, "413": { "$ref": "#/components/responses/PayloadTooLarge" }, "429": { "$ref": "#/components/responses/RateLimited" }, "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/articles/{id}": {
      "get": { "operationId": "getArticle", "summary": "Vollständigen Artikel lesen", "x-required-scope": "articles:read", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/TenantId" }], "responses": { "200": { "description": "Artikel", "headers": { "ETag": { "$ref": "#/components/headers/ETag" } } }, "404": { "$ref": "#/components/responses/NotFound" } } },
      "patch": { "operationId": "patchArticle", "summary": "Artikelstamm partiell aktualisieren", "x-required-scope": "articles:write", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/IfMatch" }], "requestBody": { "$ref": "#/components/requestBodies/JsonObject" }, "responses": { "200": { "$ref": "#/components/responses/Mutation" }, "412": { "$ref": "#/components/responses/PreconditionFailed" }, "428": { "$ref": "#/components/responses/PreconditionRequired" } } }
    },
    "/articles/{id}/tenants": {
      "get": { "operationId": "getArticleTenants", "summary": "Tenant-Zuordnungen lesen", "x-required-scope": "articles:read", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }], "responses": { "200": { "$ref": "#/components/responses/ETaggedData" } } },
      "put": { "operationId": "setArticleTenants", "summary": "Tenant-Zielzustand setzen", "x-required-scope": "articles:write", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/IfMatch" }], "requestBody": { "$ref": "#/components/requestBodies/JsonObject" }, "responses": { "200": { "$ref": "#/components/responses/Mutation" }, "412": { "$ref": "#/components/responses/PreconditionFailed" }, "428": { "$ref": "#/components/responses/PreconditionRequired" } } }
    },
    "/articles/{id}/prices": { "get": { "operationId": "getArticlePrices", "summary": "Verkaufspreise lesen", "x-required-scope": "prices:read", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/TenantId" }], "responses": { "200": { "$ref": "#/components/responses/ETaggedData" } } } },
    "/articles/{id}/prices/{priceId}": { "put": { "operationId": "setArticlePrice", "summary": "Netto-geführten Preis samt Staffelkontext setzen", "x-required-scope": "prices:write", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "name": "priceId", "in": "path", "required": true, "schema": { "type": "string" } }, { "$ref": "#/components/parameters/IfMatch" }], "requestBody": { "$ref": "#/components/requestBodies/JsonObject" }, "responses": { "200": { "$ref": "#/components/responses/Mutation" }, "412": { "$ref": "#/components/responses/PreconditionFailed" }, "428": { "$ref": "#/components/responses/PreconditionRequired" } } } },
    "/articles/{id}/inventory": { "get": { "operationId": "getArticleInventory", "summary": "Bestände lesen", "x-required-scope": "inventory:read", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }], "responses": { "200": { "$ref": "#/components/responses/ETaggedData" } } } },
    "/articles/{id}/inventory-adjustments": { "post": { "operationId": "adjustInventory", "summary": "Bestand idempotent als Delta buchen", "x-required-scope": "inventory:write", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/IdempotencyKey" }], "requestBody": { "$ref": "#/components/requestBodies/JsonObject" }, "responses": { "201": { "$ref": "#/components/responses/Mutation" }, "422": { "$ref": "#/components/responses/UnprocessableEntity" } } } },
    "/articles/{id}/categories": {
      "get": { "operationId": "getArticleCategories", "summary": "Kategorien lesen", "x-required-scope": "categories:read", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }], "responses": { "200": { "$ref": "#/components/responses/ETaggedData" } } },
      "put": { "operationId": "setArticleCategories", "summary": "Kategorien und Standardkategorie vollständig ersetzen", "x-required-scope": "categories:write", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/IfMatch" }], "requestBody": { "$ref": "#/components/requestBodies/JsonObject" }, "responses": { "200": { "$ref": "#/components/responses/Mutation" }, "422": { "$ref": "#/components/responses/UnprocessableEntity" } } }
    },
    "/articles/{id}/deactivate": { "post": { "operationId": "deactivateArticle", "summary": "Artikel sicher deaktivieren", "x-required-scope": "articles:lifecycle", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/IdempotencyKey" }], "requestBody": { "$ref": "#/components/requestBodies/JsonObject" }, "responses": { "200": { "$ref": "#/components/responses/Mutation" } } } },
    "/articles/{id}/activate": { "post": { "operationId": "activateArticle", "summary": "Artikel reaktivieren", "x-required-scope": "articles:lifecycle", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/IdempotencyKey" }], "requestBody": { "$ref": "#/components/requestBodies/JsonObject" }, "responses": { "200": { "$ref": "#/components/responses/Mutation" } } } },
    "/articles/{id}/suppliers": { "get": { "operationId": "getArticleSuppliers", "summary": "Lieferantenzuordnungen lesen", "x-required-scope": "suppliers:read", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }], "responses": { "200": { "$ref": "#/components/responses/ETaggedData" } } } },
    "/articles/{id}/suppliers/{supplierId}": {
      "put": { "operationId": "upsertArticleSupplier", "summary": "Lieferant und Einkaufspreis setzen", "x-required-scope": "suppliers:write", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/SupplierId" }, { "$ref": "#/components/parameters/IfMatch" }], "requestBody": { "$ref": "#/components/requestBodies/JsonObject" }, "responses": { "200": { "$ref": "#/components/responses/Mutation" } } },
      "delete": { "operationId": "deleteArticleSupplier", "summary": "Lieferantenzuordnung entfernen", "x-required-scope": "suppliers:write", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/SupplierId" }, { "$ref": "#/components/parameters/IfMatch" }], "responses": { "200": { "$ref": "#/components/responses/Mutation" } } }
    },
    "/articles/{id}/images/{imageId}": {
      "patch": { "operationId": "patchArticleImage", "summary": "Bildmetadaten und Zuordnungen ändern", "x-required-scope": "images:write", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/ImageId" }, { "$ref": "#/components/parameters/IfMatch" }], "requestBody": { "$ref": "#/components/requestBodies/JsonObject" }, "responses": { "200": { "$ref": "#/components/responses/Mutation" } } },
      "delete": { "operationId": "deleteArticleImage", "summary": "Bildzuordnung oder physisches Bild entfernen", "x-required-scope": "images:write", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/ImageId" }, { "$ref": "#/components/parameters/IfMatch" }, { "name": "tenantId", "in": "query", "schema": { "type": "integer" } }, { "name": "physical", "in": "query", "schema": { "type": "boolean", "default": false } }], "responses": { "200": { "$ref": "#/components/responses/Mutation" }, "422": { "$ref": "#/components/responses/UnprocessableEntity" } } }
    },
    "/articles/{id}/images/order": { "put": { "operationId": "orderArticleImages", "summary": "Vollständige Bildreihenfolge setzen", "x-required-scope": "images:write", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/IfMatch" }], "requestBody": { "$ref": "#/components/requestBodies/JsonObject" }, "responses": { "200": { "$ref": "#/components/responses/Mutation" }, "422": { "$ref": "#/components/responses/UnprocessableEntity" } } } },
    "/articles/{id}/attributes/{attributeId}": { "delete": { "operationId": "deleteArticleAttribute", "summary": "Attributzuordnung entfernen", "x-required-scope": "attributes:write", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "name": "attributeId", "in": "path", "required": true, "schema": { "type": "string" } }, { "$ref": "#/components/parameters/IfMatch" }], "responses": { "200": { "$ref": "#/components/responses/Mutation" } } } },
    "/articles/{id}/variations/{variationId}": { "patch": { "operationId": "patchVariation", "summary": "Variation aktualisieren", "x-required-scope": "articles:write", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "name": "variationId", "in": "path", "required": true, "schema": { "type": "string" } }, { "$ref": "#/components/parameters/IfMatch" }], "requestBody": { "$ref": "#/components/requestBodies/JsonObject" }, "responses": { "200": { "$ref": "#/components/responses/Mutation" } } } },
    "/articles/{id}/variation-values/{valueId}": {
      "patch": { "operationId": "patchVariationValue", "summary": "Variationswert aktualisieren", "x-required-scope": "articles:write", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/ValueId" }, { "$ref": "#/components/parameters/IfMatch" }], "requestBody": { "$ref": "#/components/requestBodies/JsonObject" }, "responses": { "200": { "$ref": "#/components/responses/Mutation" } } },
      "delete": { "operationId": "deleteVariationValue", "summary": "Unbenutzten Variationswert entfernen", "x-required-scope": "articles:write", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/ValueId" }, { "$ref": "#/components/parameters/IfMatch" }], "responses": { "200": { "$ref": "#/components/responses/Mutation" }, "409": { "$ref": "#/components/responses/Conflict" } } }
    },
    "/articles/{id}/children/{childId}/values": { "put": { "operationId": "setChildValues", "summary": "Vollständige Variationskombination eines Kindartikels setzen", "x-required-scope": "articles:write", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "name": "childId", "in": "path", "required": true, "schema": { "type": "string" } }, { "$ref": "#/components/parameters/IfMatch" }], "requestBody": { "$ref": "#/components/requestBodies/JsonObject" }, "responses": { "200": { "$ref": "#/components/responses/Mutation" }, "422": { "$ref": "#/components/responses/UnprocessableEntity" } } } },
    "/jobs/article-updates": { "post": { "operationId": "createArticleUpdateJob", "summary": "Asynchronen Artikel-Updateauftrag anlegen", "x-required-scope": "articles:write", "requestBody": { "$ref": "#/components/requestBodies/JsonObject" }, "responses": { "202": { "description": "Auftrag angenommen" } } } },
    "/jobs/{jobId}": { "get": { "operationId": "getJob", "summary": "Auftragsstatus lesen", "x-required-scope": "articles:write", "parameters": [{ "$ref": "#/components/parameters/JobId" }], "responses": { "200": { "description": "Status" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/jobs/{jobId}/results": { "get": { "operationId": "getJobResults", "summary": "Einzelergebnisse eines Auftrags lesen", "x-required-scope": "articles:write", "parameters": [{ "$ref": "#/components/parameters/JobId" }], "responses": { "200": { "description": "Einzelergebnisse" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/changes": { "get": { "operationId": "getChanges", "summary": "Cursorbasierten Änderungsfeed lesen", "x-required-scope": "articles:read", "parameters": [{ "name": "since", "in": "query", "schema": { "type": "string" } }, { "name": "types", "in": "query", "schema": { "type": "string" } }, { "name": "pageSize", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 500, "default": 100 } }], "responses": { "200": { "description": "Änderungsereignisse und nextCursor" } } } },
    "/articles/{id}/attributes": {
      "post": {
        "operationId": "setArticleAttribute",
        "summary": "Attributwert setzen oder bei Tag-Attributen ergänzen",
        "parameters": [{ "$ref": "#/components/parameters/ArticleId" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SetAttributeInput" } } } },
        "responses": {
          "200": { "description": "Vorhandener Wert geändert", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SetAttributeResponse" } } } },
          "201": { "description": "Wert neu zugewiesen", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SetAttributeResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "409": { "$ref": "#/components/responses/Conflict" }, "429": { "$ref": "#/components/responses/RateLimited" }, "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/articles/{id}/images": {
      "get": { "operationId": "getArticleImages", "summary": "Bildmetadaten lesen", "x-required-scope": "images:read", "parameters": [{ "$ref": "#/components/parameters/ArticleId" }], "responses": { "200": { "description": "Bilder", "headers": { "ETag": { "$ref": "#/components/headers/ETag" } } }, "404": { "$ref": "#/components/responses/NotFound" } } },
      "post": {
        "operationId": "uploadArticleImage",
        "summary": "Artikelbild idempotent hochladen",
        "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/IdempotencyKey" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateImageInput" } } } },
        "responses": {
          "201": { "description": "Bild angelegt", "headers": { "X-Idempotent-Replay": { "$ref": "#/components/headers/IdempotentReplay" } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateImageResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "409": { "$ref": "#/components/responses/Conflict" }, "413": { "$ref": "#/components/responses/PayloadTooLarge" }, "429": { "$ref": "#/components/responses/RateLimited" }, "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/articles/{id}/variations": {
      "post": {
        "operationId": "createVariation",
        "summary": "Variation und Werte idempotent anlegen",
        "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/IdempotencyKey" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateVariationInput" } } } },
        "responses": {
          "201": { "description": "Variation angelegt", "headers": { "X-Idempotent-Replay": { "$ref": "#/components/headers/IdempotentReplay" } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateVariationResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "409": { "$ref": "#/components/responses/Conflict" }, "413": { "$ref": "#/components/responses/PayloadTooLarge" }, "429": { "$ref": "#/components/responses/RateLimited" }, "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/articles/{id}/children": {
      "post": {
        "operationId": "createChildArticle",
        "summary": "Kindartikel anlegen oder vorhandenen Artikel idempotent zuordnen",
        "parameters": [{ "$ref": "#/components/parameters/ArticleId" }, { "$ref": "#/components/parameters/IdempotencyKey" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateChildInput" } } } },
        "responses": {
          "201": { "description": "Kindartikel angelegt oder zugeordnet", "headers": { "X-Idempotent-Replay": { "$ref": "#/components/headers/IdempotentReplay" } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateChildResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "409": { "$ref": "#/components/responses/Conflict" }, "413": { "$ref": "#/components/responses/PayloadTooLarge" }, "429": { "$ref": "#/components/responses/RateLimited" }, "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/articles/{id}/base-price": {
      "patch": {
        "operationId": "updateBasePrice",
        "summary": "Grundpreisangaben zustandsorientiert ersetzen",
        "description": "Die API rechnet Einheiten nicht um. measureQuantity und basePriceQuantity beziehen sich auf die über /context gelieferten JTL-Maßeinheiten.",
        "parameters": [{ "$ref": "#/components/parameters/ArticleId" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateBasePriceInput" } } } },
        "responses": {
          "200": { "description": "Grundpreis aktualisiert", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateBasePriceResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "409": { "$ref": "#/components/responses/Conflict" }, "429": { "$ref": "#/components/responses/RateLimited" }, "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/articles/{id}/descriptions": {
      "put": {
        "operationId": "upsertDescription",
        "summary": "Vollständigen Beschreibungskontext ersetzen oder anlegen",
        "description": "PUT-Ersetzungssemantik: nicht übermittelte optionale Inhaltsfelder werden als null gespeichert.",
        "parameters": [{ "$ref": "#/components/parameters/ArticleId" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpsertDescriptionInput" } } } },
        "responses": {
          "200": { "description": "Vorhandener Kontext ersetzt", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpsertDescriptionResponse" } } } },
          "201": { "description": "Kontext angelegt", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpsertDescriptionResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "409": { "$ref": "#/components/responses/Conflict" }, "413": { "$ref": "#/components/responses/PayloadTooLarge" }, "429": { "$ref": "#/components/responses/RateLimited" }, "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": { "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "Artikelwerk API token (aw_…)" } },
    "parameters": {
