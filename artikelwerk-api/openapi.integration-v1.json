      "CreateImageResponse": { "type": "object", "required": ["operationId", "image"], "properties": { "operationId": { "type": "string", "format": "uuid" }, "image": { "$ref": "#/components/schemas/CreatedImage" } }, "example": { "operationId": "f9be70ad-24b9-45b6-9301-32173972f457", "image": { "id": "765", "articleId": "12345", "filename": "CYL-00999-01.jpg", "width": 1600, "height": 1200, "previewWidth": 200, "previewHeight": 150, "order": 1, "tenantIds": [4] } } },
      "VariationValueInput": { "type": "object", "additionalProperties": false, "required": ["name"], "properties": { "name": { "type": "string", "minLength": 1, "maxLength": 255 }, "sku": { "type": ["string", "null"], "maxLength": 100 }, "gtin": { "type": ["string", "null"], "maxLength": 255 }, "surchargeNet": { "type": "number", "default": 0 }, "weightDelta": { "type": "number", "default": 0 }, "stock": { "type": "number", "default": 0 }, "active": { "type": "boolean", "default": true } } },
      "CreateVariationInput": { "type": "object", "additionalProperties": false, "required": ["name", "values"], "properties": { "name": { "type": "string", "minLength": 1, "maxLength": 255 }, "type": { "type": "string", "enum": ["SELECTBOX", "IMGSWATCHES"], "default": "SELECTBOX" }, "values": { "type": "array", "minItems": 1, "maxItems": 200, "items": { "$ref": "#/components/schemas/VariationValueInput" } } }, "example": { "name": "Größe", "type": "SELECTBOX", "values": [{ "name": "250 ml", "sku": "CYL-00999-250", "gtin": null, "surchargeNet": 0, "weightDelta": 0, "stock": 0, "active": true }] } },
      "CreatedVariation": { "type": "object", "required": ["id", "articleId", "name", "values"], "properties": { "id": { "type": "string" }, "articleId": { "type": "string" }, "name": { "type": "string" }, "values": { "type": "array", "items": { "type": "object", "required": ["id", "name"], "properties": { "id": { "type": "string" }, "name": { "type": "string" } } } } } },
      "CreateVariationResponse": { "type": "object", "required": ["operationId", "variation"], "properties": { "operationId": { "type": "string", "format": "uuid" }, "variation": { "$ref": "#/components/schemas/CreatedVariation" } }, "example": { "operationId": "f9be70ad-24b9-45b6-9301-32173972f457", "variation": { "id": "850", "articleId": "12345", "name": "Größe", "values": [{ "id": "987", "name": "250 ml" }] } } },
      "CreateChildInput": { "type": "object", "additionalProperties": false, "required": ["valueIds"], "properties": { "existingArticleId": { "type": "string", "pattern": "^\\d+$" }, "sku": { "type": "string", "minLength": 1, "maxLength": 100 }, "name": { "type": "string", "minLength": 1, "maxLength": 255 }, "tenantIds": { "type": "array", "minItems": 1, "maxItems": 20, "items": { "type": "integer", "minimum": 1 } }, "valueIds": { "type": "array", "minItems": 1, "maxItems": 50, "items": { "type": "string", "pattern": "^\\d+$" } }, "active": { "type": "boolean", "default": true }, "inventoryTracking": { "type": "boolean", "default": true }, "gtin": { "type": ["string", "null"], "maxLength": 255 } }, "oneOf": [{ "required": ["existingArticleId"] }, { "required": ["sku", "name", "tenantIds"] }], "example": { "sku": "CYL-00999-250", "name": "Beispielartikel 250 ml", "tenantIds": [4], "valueIds": ["987"], "active": true, "inventoryTracking": true, "gtin": null } },
      "CreatedChild": { "type": "object", "required": ["id", "parentId", "sku", "name", "valueIds", "created"], "properties": { "id": { "type": "string" }, "parentId": { "type": "string" }, "sku": { "type": "string" }, "name": { "type": "string" }, "valueIds": { "type": "array", "items": { "type": "string" } }, "created": { "type": "boolean" } } },
      "CreateChildResponse": { "type": "object", "required": ["operationId", "child"], "properties": { "operationId": { "type": "string", "format": "uuid" }, "child": { "$ref": "#/components/schemas/CreatedChild" } }, "example": { "operationId": "f9be70ad-24b9-45b6-9301-32173972f457", "child": { "id": "12346", "parentId": "12345", "sku": "CYL-00999-250", "name": "Beispielartikel 250 ml", "valueIds": ["987"], "created": true } } },
      "UpdateBasePriceInput": { "type": "object", "additionalProperties": false, "required": ["measureUnitId", "measureQuantity", "basePriceUnitId", "basePriceQuantity"], "properties": { "measureUnitId": { "type": "integer", "minimum": 0 }, "measureQuantity": { "type": "number", "minimum": 0 }, "basePriceUnitId": { "type": "integer", "minimum": 0 }, "basePriceQuantity": { "type": "number", "exclusiveMinimum": 0 } }, "example": { "measureUnitId": 1, "measureQuantity": 500, "basePriceUnitId": 2, "basePriceQuantity": 1000 } },
      "UpdatedBasePrice": { "allOf": [{ "type": "object", "required": ["articleId"], "properties": { "articleId": { "type": "string" } } }, { "$ref": "#/components/schemas/UpdateBasePriceInput" }] },
      "UpdateBasePriceResponse": { "type": "object", "required": ["operationId", "basePrice"], "properties": { "operationId": { "type": "string", "format": "uuid" }, "basePrice": { "$ref": "#/components/schemas/UpdatedBasePrice" } }, "example": { "operationId": "f9be70ad-24b9-45b6-9301-32173972f457", "basePrice": { "articleId": "12345", "measureUnitId": 1, "measureQuantity": 500, "basePriceUnitId": 2, "basePriceQuantity": 1000 } } },
      "UpsertDescriptionInput": { "type": "object", "additionalProperties": false, "required": ["languageId", "platformId", "tenantId"], "properties": { "languageId": { "type": "integer", "minimum": 0 }, "platformId": { "type": "integer", "minimum": 0 }, "tenantId": { "type": "integer", "minimum": 0 }, "name": { "type": ["string", "null"], "maxLength": 255 }, "description": { "type": ["string", "null"], "maxLength": 2000000 }, "shortDescription": { "type": ["string", "null"], "maxLength": 2000000 }, "urlPath": { "type": ["string", "null"], "maxLength": 255 }, "metaDescription": { "type": ["string", "null"], "maxLength": 2000000 }, "titleTag": { "type": ["string", "null"], "maxLength": 4000 }, "metaKeywords": { "type": ["string", "null"], "maxLength": 4000 } }, "example": { "languageId": 1, "platformId": 1, "tenantId": 4, "name": "Beispielartikel", "description": "<p>Lange Beschreibung</p>", "shortDescription": "<p>Kurzbeschreibung</p>", "urlPath": "beispielartikel", "metaDescription": "Meta-Description", "titleTag": "Beispielartikel kaufen", "metaKeywords": "pflege, leder" } },
      "UpdatedDescription": { "type": "object", "required": ["articleId", "languageId", "platformId", "tenantId", "created"], "properties": { "articleId": { "type": "string" }, "languageId": { "type": "integer" }, "platformId": { "type": "integer" }, "tenantId": { "type": "integer" }, "created": { "type": "boolean" } } },
      "UpsertDescriptionResponse": { "type": "object", "required": ["operationId", "description"], "properties": { "operationId": { "type": "string", "format": "uuid" }, "description": { "$ref": "#/components/schemas/UpdatedDescription" } }, "example": { "operationId": "f9be70ad-24b9-45b6-9301-32173972f457", "description": { "articleId": "12345", "languageId": 1, "platformId": 1, "tenantId": 4, "created": false } } }
    }
  }
