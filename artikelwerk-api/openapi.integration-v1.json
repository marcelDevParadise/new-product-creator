      "IdempotencyKey": { "name": "Idempotency-Key", "in": "header", "required": true, "description": "Beim Retry derselben fachlichen Operation unverändert wiederverwenden.", "schema": { "type": "string", "pattern": "^[A-Za-z0-9_.:-]{8,100}$" }, "example": "job-4711-create-article" }
    },
    "requestBodies": { "JsonObject": { "required": true, "content": { "application/json": { "schema": { "type": "object", "additionalProperties": true } } } } },
    "headers": { "IdempotentReplay": { "description": "true, wenn die gespeicherte Antwort eines identischen Requests wiedergegeben wurde.", "schema": { "type": "string", "const": "true" } }, "ETag": { "description": "Aktuelle unveränderliche Artikelrevision", "schema": { "type": "string", "pattern": "^\"0x[0-9A-F]+\"$" } } },
    "responses": {
      "BadRequest": { "description": "Request oder fachlicher Wert ungültig", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "Unauthorized": { "description": "Bearer-Token fehlt oder ist ungültig", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "Forbidden": { "description": "Erforderlicher Scope fehlt", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "NotFound": { "description": "Artikel oder Vaterartikel nicht gefunden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "Conflict": { "description": "SKU, Kontext, Mandant, Idempotency-Key oder parallele Änderung kollidiert", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "PreconditionFailed": { "description": "If-Match stimmt nicht mit der aktuellen Revision überein", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "PreconditionRequired": { "description": "If-Match fehlt", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "UnprocessableEntity": { "description": "Fachlich nicht ausführbarer Zielzustand", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "Mutation": { "description": "Änderung erfolgreich", "headers": { "ETag": { "$ref": "#/components/headers/ETag" } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MutationResult" } } } },
      "ETaggedData": { "description": "Daten erfolgreich gelesen", "headers": { "ETag": { "$ref": "#/components/headers/ETag" } }, "content": { "application/json": { "schema": {} } } },
      "PayloadTooLarge": { "description": "JSON-Request überschreitet 15 MiB", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "RateLimited": { "description": "Mehr als 120 Requests pro Minute für den Token", "headers": { "Retry-After": { "description": "Wartezeit in Sekunden", "schema": { "type": "integer", "minimum": 1 } }, "X-RateLimit-Limit": { "schema": { "type": "integer", "example": 120 } }, "X-RateLimit-Remaining": { "schema": { "type": "integer", "minimum": 0 } } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "InternalError": { "description": "Interner oder SQL-Fehler", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
    },
    "schemas": {
      "Error": { "type": "object", "required": ["code", "error", "requestId"], "properties": { "code": { "type": "string", "enum": ["BAD_REQUEST", "VALIDATION_ERROR", "UNAUTHORIZED", "FORBIDDEN", "NOT_FOUND", "CONFLICT", "PRECONDITION_FAILED", "PRECONDITION_REQUIRED", "UNPROCESSABLE_ENTITY", "PAYLOAD_TOO_LARGE", "RATE_LIMITED", "INTERNAL_ERROR"] }, "error": { "type": "string" }, "requestId": { "type": "string" }, "details": {} }, "example": { "code": "CONFLICT", "error": "Der Idempotency-Key wurde bereits für einen anderen Request verwendet.", "requestId": "req-17" } },
      "MutationResult": { "type": "object", "required": ["operationId", "revision", "changedFields"], "properties": { "operationId": { "type": "string", "format": "uuid" }, "revision": { "type": "string" }, "changedFields": { "type": "array", "items": { "type": "string" } } }, "additionalProperties": true },
