# PostgreSQL Connection — kopiere diese Datei zu .env und passe die Werte an.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://attributgen:DEIN_PASSWORT@100.87.118.91:5432/attribut_generator

# CORS — kommaseparierte Origins die das Frontend erreichen darf.
# Lokal:    http://localhost:5173,http://127.0.0.1:5173
# Auf Pi:   https://<host>.<tailnet>.ts.net
# Wildcard: *
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Persistente Laufzeit-Einstellungen. Ohne Angabe wird die ignorierte Datei
# backend/data/settings.local.json verwendet.
# SETTINGS_PATH=/absoluter/pfad/settings.local.json

# Artikelwerk Integrations-API. Der Key bleibt ausschließlich im Backend.
# Wenn Artikelwerk auf demselben Pi läuft, den internen Loopback-Port verwenden:
# ARTIKELWERK_BASE_URL=http://127.0.0.1:3000/api/integrations/v1
ARTIKELWERK_BASE_URL=http://127.0.0.1:3000/api/integrations/v1
ARTIKELWERK_API_KEY=aw_...
ARTIKELWERK_TIMEOUT_SECONDS=30
ARTIKELWERK_VERIFY_TLS=true
