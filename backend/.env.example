# PostgreSQL Connection — kopiere diese Datei zu .env und passe die Werte an.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://attributgen:DEIN_PASSWORT@100.87.118.91:5432/attribut_generator

# CORS — kommaseparierte Origins die das Frontend erreichen darf.
# Lokal:    http://localhost:5173,http://127.0.0.1:5173
# Auf Pi:   https://<host>.<tailnet>.ts.net
# Wildcard: *
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
