# Datenbank-Verbindung.
# Lokaler Test (SQLite, Datei wird automatisch angelegt):
DATABASE_URL=sqlite:///./backend/products.db
# Produktion (Pi / PostgreSQL):
# DATABASE_URL=postgresql://attributgen:pass1234@100.87.118.91:5432/attribut_generator

# CORS — kommaseparierte Origins die das Frontend erreichen darf.
# Lokal:    http://localhost:5173,http://127.0.0.1:5173
# Auf Pi:   https://<host>.<tailnet>.ts.net
# Wildcard: *
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Artikelwerk Integrations-API. Der Key bleibt ausschließlich im Backend.
ARTIKELWERK_BASE_URL=http://127.0.0.1:3000/api/integrations/v1
ARTIKELWERK_API_KEY=aw_...
ARTIKELWERK_TIMEOUT_SECONDS=30
ARTIKELWERK_VERIFY_TLS=true